<Window x:Class="GsmAgent.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:GsmAgent.Views"
    Title="GSM Agent" Height="620" Width="520"
    MinHeight="500" MinWidth="440"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="{StaticResource BgPrimaryBrush}">

    <Window.Resources>
        <!-- DataGrid Row Style -->
        <Style x:Key="ModernDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a58a6ff"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2058a6ff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Cell Style -->
        <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Column Header Style -->
        <Style x:Key="ModernColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="8,8,8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        </Style>

        <!-- Filter chip button -->
        <Style x:Key="FilterChip" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER ═══════════════ -->
        <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource BorderSubtleBrush}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#161b22" Offset="0"/>
                    <GradientStop Color="#1a2332" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#58a6ff" Offset="0"/>
                                <GradientStop Color="#bc8cff" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="📡" FontSize="14" HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="GSM Agent" FontSize="15" FontWeight="Bold"
                            Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Settings.AgentId}" FontSize="9"
                            Foreground="{StaticResource TextSecondaryBrush}" Margin="0,-1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- MongoDB status -->
                <Border Grid.Column="2" CornerRadius="10" Padding="8,3" Margin="0,0,8,0"
                    VerticalAlignment="Center" Background="#1a30363d">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Margin="0,0,5,0"
                            Fill="{Binding MongoStatusColor}"/>
                        <TextBlock Text="MongoDB" Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Server connection status -->
                <Border Grid.Column="3" CornerRadius="10" Padding="8,3"
                    VerticalAlignment="Center" Background="#1a30363d">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Margin="0,0,5,0"
                            Fill="{Binding ServerStatusColor}"/>
                        <TextBlock Text="{Binding ServerStatus}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════ STATS CARDS ═══════════════ -->
        <Border Grid.Row="1" Padding="12,10" Background="{StaticResource BgPrimaryBrush}">
            <UniformGrid Columns="4" Rows="1">
                <!-- SIMs Online -->
                <Border CornerRadius="8" Margin="3" Padding="10,8"
                    BorderThickness="1" BorderBrush="#1a3fb950"
                    Background="#0d3fb950">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding OnlineSimCount}" FontSize="22" FontWeight="Bold"
                            Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="SIMs Online" FontSize="9"
                            Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                            Margin="0,-2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Sent -->
                <Border CornerRadius="8" Margin="3" Padding="10,8"
                    BorderThickness="1" BorderBrush="#1a58a6ff"
                    Background="#0d58a6ff">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalSentCount}" FontSize="22" FontWeight="Bold"
                            Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Đã gửi" FontSize="9"
                            Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                            Margin="0,-2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Queue -->
                <Border CornerRadius="8" Margin="3" Padding="10,8"
                    BorderThickness="1" BorderBrush="#1ad29922"
                    Background="#0dd29922">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalQueueSize}" FontSize="22" FontWeight="Bold"
                            Foreground="{StaticResource AccentYellowBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Hàng đợi" FontSize="9"
                            Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                            Margin="0,-2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Rate Limited -->
                <Border CornerRadius="8" Margin="3" Padding="10,8"
                    BorderThickness="1" BorderBrush="#1af85149"
                    Background="#0df85149">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding RateLimitedCount}" FontSize="22" FontWeight="Bold"
                            Foreground="{StaticResource AccentRedBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bị giới hạn" FontSize="9"
                            Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                            Margin="0,-2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <!-- ═══════════════ MAIN TAB CONTROL ═══════════════ -->
        <TabControl Grid.Row="2" Margin="0" Padding="0" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                    Background="Transparent" BorderThickness="0,0,0,2"
                                    BorderBrush="Transparent" Cursor="Hand">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="BorderBrush"
                                            Value="{StaticResource AccentBlueBrush}"/>
                                        <Setter Property="Foreground"
                                            Value="{StaticResource TextPrimaryBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#10ffffff"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ═══════ TAB 1: SIM List ═══════ -->
            <TabItem Header="📱  SIM Cards">
                <Grid Margin="12,10,12,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource ModernButton}"
                            Command="{Binding ScanCommand}" Margin="0,0,6,0"
                            ToolTip="Scan tất cả COM ports">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#58a6ff" Offset="0"/>
                                    <GradientStop Color="#388bfd" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" Margin="0,0,5,0"/>
                                <TextBlock Text="Scan"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" Style="{StaticResource ModernButton}"
                            Command="{Binding StartWorkersCommand}" Margin="0,0,6,0"
                            ToolTip="Khởi động workers và kết nối server">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#3fb950" Offset="0"/>
                                    <GradientStop Color="#2ea043" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Margin="0,0,5,0"/>
                                <TextBlock Text="Start"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" Style="{StaticResource ModernButton}"
                            Command="{Binding StopWorkersCommand}" Margin="0,0,6,0"
                            ToolTip="Dừng tất cả workers">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#f85149" Offset="0"/>
                                    <GradientStop Color="#da3633" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏹" Margin="0,0,5,0"/>
                                <TextBlock Text="Stop"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3" Style="{StaticResource ModernButton}"
                            Command="{Binding SyncMongoCommand}" Padding="10,8"
                            ToolTip="Sync SIM → MongoDB ngay">
                            <Button.Background>
                                <SolidColorBrush Color="#30363d"/>
                            </Button.Background>
                            <TextBlock Text="🔄 Sync DB" FontSize="11"/>
                        </Button>

                        <TextBlock Grid.Column="4" Text="{Binding ScanStatus}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            VerticalAlignment="Center" HorizontalAlignment="Right"
                            FontSize="10" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- SIM DataGrid -->
                    <Border Grid.Row="1" CornerRadius="8" BorderThickness="1"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        Background="{StaticResource BgSecondaryBrush}">
                        <DataGrid ItemsSource="{Binding SimList}" AutoGenerateColumns="False"
                            IsReadOnly="True" Background="Transparent"
                            Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                            GridLinesVisibility="None"
                            RowStyle="{StaticResource ModernDataGridRow}"
                            CellStyle="{StaticResource ModernDataGridCell}"
                            ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                            HeadersVisibility="Column" FontSize="11.5" RowHeight="32"
                            SelectionMode="Single" SelectionUnit="FullRow"
                            CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="COM" Binding="{Binding ComPort}" Width="60"/>
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusDisplay}" Width="70"/>
                                <DataGridTextColumn Header="Số điện thoại" Binding="{Binding PhoneNumber}" Width="110"/>
                                <DataGridTextColumn Header="Nhà mạng" Binding="{Binding Provider}" Width="85"/>
                                <DataGridTextColumn Header="Sóng" Binding="{Binding SignalDisplay}" Width="50"/>
                                <DataGridTextColumn Header="Gửi" Binding="{Binding DailyCountDisplay}" Width="55"/>
                                <DataGridTextColumn Header="Fail" Binding="{Binding TotalFailed}" Width="40"/>
                                <DataGridTextColumn Header="Q" Binding="{Binding QueueSize}" Width="35"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════ TAB 2: Messages ═══════ -->
            <TabItem Header="💬  Tin nhắn">
                <Grid Margin="12,10,12,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filter Chips -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource FilterChip}"
                            Command="{Binding FilterMessagesCommand}" CommandParameter="ALL">
                            <Button.Background>
                                <SolidColorBrush Color="#30363d"/>
                            </Button.Background>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                    <Setter Property="Background" Value="#30363d"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilter}" Value="ALL">
                                            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="📋 Tất cả"/>
                        </Button>

                        <Button Command="{Binding FilterMessagesCommand}" CommandParameter="IN">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                    <Setter Property="Background" Value="#30363d"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilter}" Value="IN">
                                            <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📨 Nhận" VerticalAlignment="Center"/>
                                <Border Background="#203fb950" CornerRadius="8" Padding="5,1"
                                    Margin="5,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding IncomingCount}" FontSize="10"
                                        Foreground="{StaticResource AccentGreenBrush}"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterMessagesCommand}" CommandParameter="OUT">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                    <Setter Property="Background" Value="#30363d"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilter}" Value="OUT">
                                            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📤 Gửi" VerticalAlignment="Center"/>
                                <Border Background="#2058a6ff" CornerRadius="8" Padding="5,1"
                                    Margin="5,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding OutgoingCount}" FontSize="10"
                                        Foreground="{StaticResource AccentBlueBrush}"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterMessagesCommand}" CommandParameter="FAILED">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                    <Setter Property="Background" Value="#30363d"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilter}" Value="FAILED">
                                            <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❌ Lỗi" VerticalAlignment="Center"/>
                                <Border Background="#20f85149" CornerRadius="8" Padding="5,1"
                                    Margin="5,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FailedCount}" FontSize="10"
                                        Foreground="{StaticResource AccentRedBrush}"/>
                                </Border>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Message DataGrid -->
                    <Border Grid.Row="1" CornerRadius="8" BorderThickness="1"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        Background="{StaticResource BgSecondaryBrush}">
                        <DataGrid ItemsSource="{Binding FilteredMessages}" AutoGenerateColumns="False"
                            IsReadOnly="True" Background="Transparent"
                            Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                            GridLinesVisibility="None"
                            RowStyle="{StaticResource ModernDataGridRow}"
                            CellStyle="{StaticResource ModernDataGridCell}"
                            ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                            HeadersVisibility="Column" FontSize="11.5" RowHeight="32"
                            SelectionMode="Single" SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="" Binding="{Binding DirectionIcon}" Width="30"/>
                                <DataGridTextColumn Header="Loại" Binding="{Binding DirectionText}" Width="45"/>
                                <DataGridTextColumn Header="Số điện thoại" Binding="{Binding PhoneDisplay}" Width="110"/>
                                <DataGridTextColumn Header="Nội dung" Binding="{Binding ShortContent}" Width="*"/>
                                <DataGridTextColumn Header="Thời gian" Binding="{Binding TimeDisplay}" Width="100"/>
                                <DataGridTextColumn Header="" Binding="{Binding StatusIcon}" Width="30"/>
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="75"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════ TAB 3: Gửi SMS ═══════ -->
            <TabItem Header="📤  Gửi SMS">
                <Grid Margin="12,10,12,6">
                    <Border CornerRadius="10" BorderThickness="1"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        Background="{StaticResource BgSecondaryBrush}"
                        Padding="20,16" VerticalAlignment="Top">
                        <StackPanel>
                            <!-- Title -->
                            <TextBlock Text="Gửi tin nhắn SMS" FontSize="16" FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                            <!-- Chọn SIM -->
                            <TextBlock Text="Chọn SIM gửi" FontSize="11"
                                Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding SimList}"
                                SelectedItem="{Binding SelectedSim}"
                                Background="{StaticResource BgCardBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1" Padding="10,8" FontSize="12"
                                Margin="0,0,0,14">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SimDisplayName}"
                                            Foreground="#f0f6fc"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Số đích -->
                            <TextBlock Text="Số điện thoại đích" FontSize="11"
                                Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SmsDestNumber, UpdateSourceTrigger=PropertyChanged}"
                                Background="{StaticResource BgCardBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1" Padding="10,8" FontSize="13"
                                Margin="0,0,0,14"
                                CaretBrush="{StaticResource AccentBlueBrush}"/>

                            <!-- Nội dung -->
                            <TextBlock Text="Nội dung tin nhắn" FontSize="11"
                                Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SmsContent, UpdateSourceTrigger=PropertyChanged}"
                                Background="{StaticResource BgCardBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1" Padding="10,8" FontSize="13"
                                Height="80" TextWrapping="Wrap"
                                AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                Margin="0,0,0,16"
                                CaretBrush="{StaticResource AccentBlueBrush}"/>

                            <!-- Nút gửi + Kết quả -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Style="{StaticResource ModernButton}"
                                    Command="{Binding SendSmsCommand}"
                                    IsEnabled="{Binding IsSending, Converter={x:Static local:InverseBoolConverter.Instance}}"
                                    Padding="20,10" Margin="0,0,12,0">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#58a6ff" Offset="0"/>
                                            <GradientStop Color="#388bfd" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📤" Margin="0,0,6,0" FontSize="14"/>
                                        <TextBlock Text="Gửi SMS" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Grid.Column="1" Text="{Binding SmsResult}"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="12" VerticalAlignment="Center"
                                    TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══════════════ STATUS BAR ═══════════════ -->
        <Border Grid.Row="3" Padding="14,6" BorderThickness="0,1,0,0"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            Background="{StaticResource BgSecondaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                    Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5"
                    TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="v1.0" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
